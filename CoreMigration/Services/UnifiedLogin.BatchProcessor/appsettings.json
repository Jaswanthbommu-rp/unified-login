{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "BatchProcessor": {
    "ThreadCount": 5,
    "PollingIntervalSeconds": 10,
    "RetryPollingIntervalSeconds": 10,
    "BatchSize": 10,
    "ExceptionWaitIntervalSeconds": 120,
    "MaxQueueSize": 100,
    "LandingApiBaseUrl": "https://localhost:5001",
    "ApiTimeoutSeconds": 30,
    "ConnectionString": "Server=localhost;Database=IdpConfiguration;Integrated Security=true;TrustServerCertificate=true;"
  },
  "OpenTelemetry": {
    "ServiceName": "UnifiedLogin.BatchProcessor",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  }
}
