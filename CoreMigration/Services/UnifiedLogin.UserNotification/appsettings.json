{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "UnifiedLogin.UserNotification": "Information"
    }
  },
  "UserNotification": {
    "IntervalSeconds": 60,
    "WorkerThreads": 3,
    "BatchSize": 50,
    "MaxRetryAttempts": 3,
    "ProcessingTimeoutSeconds": 30,
    "ConnectionString": "Server=localhost;Database=NotificationDb;Integrated Security=true;TrustServerCertificate=true;",
    "NotificationApiBaseUrl": "https://localhost:5001",
    "EnableEmailNotifications": true,
    "EnableSmsNotifications": true,
    "EnablePushNotifications": true
  },
  "OpenTelemetry": {
    "ServiceName": "UnifiedLogin.UserNotification",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  }
}
