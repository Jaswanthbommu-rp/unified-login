{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Debug",
      "UnifiedLogin.UserNotification": "Debug"
    }
  },
  "UserNotification": {
    "WorkerThreads": 2,
    "BatchSize": 10,
    "MaxRetryAttempts": 2,
    "ProcessingTimeoutSeconds": 60,
    "ConnectionString": "Server=localhost;Database=NotificationDb;Integrated Security=true;TrustServerCertificate=true;",
    "NotificationApiBaseUrl": "https://localhost:5001",
    "EnableEmailNotifications": true,
    "EnableSmsNotifications": true,
    "EnablePushNotifications": true,
    "DailyExecutionTime": "02:30:00",
    "DailyExecutionTimeZone": "Eastern Standard Time"
  }
}
