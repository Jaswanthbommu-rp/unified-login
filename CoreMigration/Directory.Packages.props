    <PackageVersion Include="LaunchDarkly.ServerSdk" Version="8.10.4" />
    <!-- Validation packages -->
    <PackageVersion Include="FluentValidation.DependencyInjectionExtensions" Version="12.0.0" />
    <!-- Data Access packages -->
    <PackageVersion Include="Dapper" Version="2.1.66" />
    <PackageVersion Include="RealPage.DataAccess.Dapper" Version="1.3.1" />
    <!-- Messaging and Cache packages -->
    <PackageVersion Include="Confluent.Kafka" Version="2.8.0" />
    <PackageVersion Include="StackExchange.Redis" Version="2.8.29" />
    <!--<PackageVersion Include="Polly" Version="8.6.0" />-->
