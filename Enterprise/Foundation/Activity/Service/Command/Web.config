<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <customErrors mode="Off" />
    <compilation debug="true" targetFramework="4.5.2" />
    <httpRuntime targetFramework="4.5.2" />
  </system.web>
  <connectionStrings>
    <add name="AuditDbCnn" connectionString="Data Source=RCDUSODBSQL001.Corp.Realpage.com;Initial Catalog=AuditDb;user id=identityserver; password=p@$$w0rd;" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <!--Elastic search related configurations-->
    <add key="ElasticSearchUri" value="http://elkdev-es-1.realpage.com:9200" />
    <add key="Environment" value="LOCAL" />
    <add key="LogPath" value="C:\Log" />
    <add key="LogProductName" value="ActivityCommand" />
    <add key="ElasticSearchIndexTypeName" value="local-unity-activitycommand" />
    <add key="ShouldWriteInFile" value="true" />
    <add key="ShouldLogPerformance" value="false" />
    <add key="ShouldLogDiagnostic" value="false" />
    <!--Elastic search related configurations-->
  </appSettings>
  <system.serviceModel>
    <behaviors>
      <serviceBehaviors>
        <behavior name="Throttled">
          <serviceThrottling maxConcurrentCalls="100" maxConcurrentInstances="100" />
          <serviceMetadata httpGetEnabled="true" httpsGetEnabled="true" />
          <serviceDebug includeExceptionDetailInFaults="true" />
        </behavior>
      </serviceBehaviors>
    </behaviors>
    <serviceHostingEnvironment aspNetCompatibilityEnabled="true" multipleSiteBindingsEnabled="true" />
    <services>
      <service name="RP.Enterprise.Foundation.Activity.Service.Logging.Command.Writer" behaviorConfiguration="Throttled">
        <endpoint name="ObjectSvc" address="msmq.formatname:DIRECT=OS:.\private$\greenbook_activity" binding="msmqIntegrationBinding" bindingConfiguration="IntQBind_Object" contract="RP.Enterprise.Foundation.Activity.Service.Logging.Command.IWriter" />

        <endpoint contract="IMetadataExchange" binding="mexHttpBinding" address="mex" />
      </service>
    </services>
    <bindings>
      <msmqIntegrationBinding>
        <!--binding config to read message as object-->
        <binding name="IntQBind_Object" exactlyOnce="false" maxReceivedMessageSize="6553600">
          <security mode="None" />
        </binding> 
      </msmqIntegrationBinding>
    </bindings>
  </system.serviceModel>
  <system.webServer>
    <!--Following config makes sure to init service automatically; may not work in local env-->
    <applicationInitialization doAppInitAfterRestart="true">
      <add initializationPage="/Writer.svc" />
    </applicationInitialization>
    <modules runAllManagedModulesForAllRequests="true" />
    <directoryBrowse enabled="true" />
  <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers></system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-12.0.0.0" newVersion="12.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Http" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.6.0" newVersion="5.2.6.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Net.Http.Formatting" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.7.0" newVersion="5.2.7.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>