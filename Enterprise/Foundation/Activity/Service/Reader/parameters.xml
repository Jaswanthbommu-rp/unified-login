<?xml version="1.0"?>
<parameters>  
  <!-- appSettings -->
  <parameter name="Environment"
           description="Activity Command environment"
           defaultValue="#{Environment}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:environment']/@value" />
  </parameter>
  <parameter name="LogPath"
             description="Local path for writing logs"
             defaultValue="#{LogPath}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:filePath']/@value" />
    <parameterValidation kind="AllowEmpty" />
  </parameter>
  <parameter name="KafkaCluster"
             description="Kafka Cluster Urls"
             defaultValue="#{KafkaCluster}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:kafkaCluster']/@value" />
  </parameter>
  <parameter name="LoggingExcludedProperties"
             description="Excluded Properties"
             defaultValue="#{LoggingExcludedProperties}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:excludedProperties']/@value" />
  </parameter>
  <parameter name="LoggingMinimumLevel"
             description="Serilog Logging Minimum Level"
             defaultValue="#{LoggingMinimumLevel}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='serilog:minimum-level']/@value" />
  </parameter>  
  <parameter name="IssuerUri"
             description="Used to identity the identity server used"
             defaultValue="#{IssuerUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='IssuerUri']/@value" />
  </parameter>
  <parameter name="IdentityServerSigningCertThumbprint"
             description="The thumbprint of the SSL certificate to use with IdentityServer"
             defaultValue="#{IdentityServerSigningCertThumbprint}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='IdentityServerSigningCertThumbprint']/@value" />
  </parameter>
  <parameter name="CorsUrls"
             description="Urls for servers allowed to post to the api"
             defaultValue="#{ActivityCorsUrls}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='CorsUrls']/@value" />
  </parameter>

  <!--APM settings-->
  <parameter name="ElasticApm_Enabled"
  	   description="Flag to on and off the APM"
  	   defaultValue="#{ElasticApm.Enabled}#">
  	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:Enabled']/@value" />
  </parameter>
  <parameter name="Environment"
  	   description="Used by APM"
  	   defaultValue="#{Environment}#">
  	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:Environment']/@value" />
  </parameter>
  <parameter name="ElasticApm_ServerUrl"
  	   description="APM Server Url"
  	   defaultValue="#{ElasticApm.ServerUrl}#">
  	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:ServerUrl']/@value" />
  </parameter>
  <parameter name="ElasticApm_ServiceVersion"
  	   description="APM Server Version / Branch Name"
  	   defaultValue="#{ElasticApm.ServiceVersion}#">
  	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:ServiceVersion']/@value" />
  </parameter>
  <parameter name="ElasticApm_TransactionSampleRate"
  	   description="TransactionSampleRate 1.0 for lower and 0.1 for PROD"
  	   defaultValue="#{ElasticApm.TransactionSampleRate}#">
  	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:TransactionSampleRate']/@value" />
  </parameter>
</parameters>