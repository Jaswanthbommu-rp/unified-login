<?xml version="1.0"?>
<parameters>
  <parameter name="IssuerUri"
             description="Used to identity the identity server used"
             defaultValue="#{IssuerUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='IssuerUri']/@value" />
  </parameter>
  <parameter name="ApiUri"
             description="Used to identify the Unity web api"
             defaultValue="#{ApiUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='ApiUri']/@value" />
  </parameter>
<parameter name="UnifiedSettingsApiUri"
        description="Used to identify the uri for the Unified Setting API"
        defaultValue="#{UnifiedSettingsApiUri}#">
	<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='UnifiedSettingsApiUri']/@value" />
</parameter>
  <parameter name="RedirectUri"
             description="Used to redirect the user to the Unity web site"
             defaultValue="#{RedirectUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='RedirectUri']/@value" />
  </parameter>
  <parameter name="LandingClientId"
             description="The client name for the Landing web"
             defaultValue="#{LandingClientId}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='LandingClientId']/@value" />
  </parameter>
  <parameter name="LandingScopes"
             description="Used to identity the scopes needed to use the APIs"
             defaultValue="#{LandingScopes}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='LandingScopes']/@value" />
  </parameter>
  <parameter name="LandingUri"
             description="Common email service to use for Unified UI email generation"
             defaultValue="#{LandingUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='LandingUri']/@value" />
  </parameter>
  <!-- appSettings -->  
  <parameter name="ActivityMQName"
             description="Product name to use for elastic search indexing"
             defaultValue="#{ActivityMQName}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ActivityMQName']/@value" />
  </parameter>
  <parameter name="ShouldLogOpenIdMessages"
             description="Should OpenId messages be logged"
             defaultValue="#{ShouldLogOpenIdMessages}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ShouldLogOpenIdMessages']/@value" />
  </parameter>
  <parameter name="StatusCheck"
             description="Used to check if servers are running correctly"
             defaultValue="#{StatusCheck}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='StatusCheck']/@value" />
  </parameter>

  <!-- Kibana -->
  <parameter name="Environment"
         description="Activity Command environment"
         defaultValue="#{Environment}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:environment']/@value" />
  </parameter>
  <parameter name="LogPath"
             description="Local path for writing logs"
             defaultValue="#{LogPath}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:filePath']/@value" />
    <parameterValidation kind="AllowEmpty" />
  </parameter>
  <parameter name="KafkaTopicName"
             description="Index Kafka Topic Name to search"
             defaultValue="#{KafkaTopicName}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:elasticIndexFormatRoot']/@value" />
  </parameter>
  <parameter name="KafkaCluster"
             description="Kafka Cluster Urls"
             defaultValue="#{KafkaCluster}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:kafkaCluster']/@value" />
  </parameter>
  <parameter name="LoggingExcludedProperties"
             description="Excluded Properties"
             defaultValue="#{LoggingExcludedProperties}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:excludedProperties']/@value" />
  </parameter>
  <parameter name="LoggingMinimumLevel"
             description="Serilog Logging Minimum Level"
             defaultValue="#{LoggingMinimumLevel}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='serilog:minimum-level']/@value" />
  </parameter> 
</parameters>