@{
    Layout = "~/Views/Shared/_LayoutJquery.cshtml";
}

<header id="raul-page-header" class="raul-page-header d-none d-md-block">
    <h2 id="raul-page-header-page" class="raul-page-header-page"></h2>
    <div id="raul-page-header-breadcrumbs" class="raul-page-header-breadcrumbs">

        <!-- MOBILE SOLUTION -->
        <div id="raul-page-header-breadcrumbs-dropdown" class="raul-page-header-breadcrumbs-dropdown d-md-none">
            <a class="raul-page-header-breadcrumbs-dropdown-breadcrumb rp-breadcrumbs-template hidden" href="/">RealPage</a>
        </div>

        <i id="raul-page-header-breadcrumbs-back" class="fa fa-angle-left d-md-none"></i>

        <!-- DESKTOP SOLUTION -->
        <div class="rp-breadcrumbs-wrapper rp-breadcrumbs-template hidden">
            <a class="raul-page-header-breadcrumb hidden-sm-down" href="/">RealPage</a>
            <span class="hidden-sm-down">/</span>
        </div>
    </div>
</header>

<main class="raul-page-container">

    <div class="settings-pages-container">

        <div class="container-fluid">
            <div class="row">

                <div class="col-md-3 col-lg-3 settings-pages-leftnav fix-leftnav p-a-0">
                    <!-- <button type="button" class="close page-leftnav-close mt-2 d-lg-none">
        <i class="fa fa-angle-left back-icon"></i>
    </button>-->


                    <div class="left-menu">
                        <div class="left-menu-head">
                            <div class="tile-name left-menu-back">
                                <i class="fa fa-angle-left back-icon page-leftnav-close"></i>
                                <span></span>
                            </div>
                            <div class="search-bar">

                                <div class="form-group">

                                    <div class="form-control-wrapper">
                                        <input type="search"
                                               name="example-input-11"
                                               class="form-control"
                                               id="example-input-11"
                                               placeholder="Search all Realpage settings" />
                                        <div class="form-icon-box">
                                            <i class="fa fa-search form-icon form-icon-search form-icon-grey" aria-hidden="true"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pages-wrapper">
                            <div class="raul-content-loader-wrapper">
                                <div class="raul-content-loader"></div>
                            </div>

                            <ul data-drilldown class="nav nav-pills nav-stacked pages-tabs" id="dynamic-pages-list"></ul>
                        </div>
                    </div>

                </div>




    <div id="dynamic-pages-content" class="tab-content px-md-4 px-lg-5 col-md-12 col-lg-9">



    </div><!-- tab content -->

</div>

        </div>

    </div>

</main>

<script src="@Url.Content("~/Assets/build/js/settings/load-scripts.js")"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadFiles([
            '/Assets/build/js/settings/page-components.js',
            '/Assets/build/js/settings/dynamic-settings.js',
        ]);
    });

</script>
