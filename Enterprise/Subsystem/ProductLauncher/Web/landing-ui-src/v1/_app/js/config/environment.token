//  Environment Constant

(function (angular) {
    "use strict";

    var envConfig = {};

    envConfig = {
        name: "token",
		landingAPI: "#{LandingAPIUri}#",
        loggingAPI: "#{LoggingAPIUri}#",
        helpUrl: "#{helpUrl}#",
		ulmtUrl: "#{ulmtUrl}#",
		currentEnv: "#{currentEnv}#",
		notificationsApiRoot: "#{NotificationsAPIUri}#/v1"
	};

	Object.freeze(envConfig);

	angular
		.module("settings")
		.constant("ENV", envConfig);
})(angular);
