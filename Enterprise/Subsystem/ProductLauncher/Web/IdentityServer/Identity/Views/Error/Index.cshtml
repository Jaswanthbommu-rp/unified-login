
@{
    ViewBag.Title = "System Error";
    string sessionId = "000000";
    if (Session != null && string.IsNullOrEmpty(Session.SessionID))
    {
        sessionId = Session.SessionID;
    }
}

<h2>Oh, No!</h2>

<div>
    Something bad happened and we have error monitors in place that will let us know that we have something to fix.
    If you want to contact us, refer to the following error id: <strong>@sessionId</strong>
</div>

