<?xml version="1.0"?>
<parameters>
  <parameter name="IssuerUri"
             description="Used to identity the identity server used"
             defaultValue="#{IssuerUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='IssuerUri']/@value" />
  </parameter>
  <parameter name="RequiredScope"
             description="Used to identify the scopes needed to use the APIs"
             defaultValue="#{RequiredScope}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='RequiredScope']/@value" />
  </parameter>
  <parameter name="LandingUri"
             description="Used to identify the Unity web site"
             defaultValue="#{LandingUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='LandingUri']/@value" />
  </parameter>
  <parameter name="ImagesUri"
             description="DAM image location"
             defaultValue="#{ImagesUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='ImagesUri']/@value" />
  </parameter>
  <parameter name="DocumentUri"
             description="DAM asset location"
             defaultValue="#{DocumentUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='DocumentUri']/@value" />
  </parameter>
  <parameter name="IdentityServerSigningCertThumbprint"
             description="The thumbprint of the SSL certificate to use with IdentityServer"
             defaultValue="#{IdentityServerSigningCertThumbprint}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='IdentityServerSigningCertThumbprint']/@value" />
  </parameter>
  <parameter name="CESURL"
             description="Common email service to use for Unified UI email generation"
             defaultValue="#{CESURL}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='CESURL']/@value" />
  </parameter>
  <parameter name="SystemGUID"
             description="Used during email generation"
             defaultValue="#{SystemGUID}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='SystemGUID']/@value" />
  </parameter>
  <parameter name="VendorServicesIssueUri"
             description="Used to override the identity server used to get the api token when calling VendorServices"
             defaultValue="#{VendorServicesIssueUri}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='VendorServicesIssueUri']/@value" />
    <parameterValidation kind="AllowEmpty" />
  </parameter>
  <parameter name="OrgMasterId"
             description="Used to store the RealPage blue book company id"
             defaultValue="#{OrgMasterId}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/IdentityConfig/add[@key='OrgMasterId']/@value" />
  </parameter>

  <!-- appSettings -->
  <parameter name="cors_allowOrigins"
             description="Origins allowed for CORS"
             defaultValue="#{cors_allowOrigins}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='cors:allowOrigins']/@value" />
  </parameter>
  <parameter name="ActivityMQName"
             description="Product name to use for elastic search indexing"
             defaultValue="#{ActivityMQName}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ActivityMQName']/@value" />
  </parameter>
  
  <parameter name="launchdarkly_SdkKey"
             description="Launch Darkly SdkKey"
             defaultValue="#{LaunchDarkly.SdkKey}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='launchdarkly:SdkKey']/@value" />
  </parameter>
    
  <!-- Kibana -->
  <parameter name="Environment"
         description="Activity Command environment"
         defaultValue="#{Environment}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:environment']/@value" />
  </parameter>
  <parameter name="LogPath"
             description="Local path for writing logs"
             defaultValue="#{LogPath}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:filePath']/@value" />
    <parameterValidation kind="AllowEmpty" />
  </parameter>
  <parameter name="KafkaCluster"
             description="Kafka Cluster Urls"
             defaultValue="#{KafkaCluster}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:kafkaCluster']/@value" />
  </parameter>
  <parameter name="LoggingExcludedProperties"
             description="Excluded Properties"
             defaultValue="#{LoggingExcludedProperties}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='logging:excludedProperties']/@value" />
  </parameter>
  <parameter name="LoggingMinimumLevel"
             description="Serilog Logging Minimum Level"
             defaultValue="#{LoggingMinimumLevel}#">
    <parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='serilog:minimum-level']/@value" />
  </parameter>

	<!--Kafka settings-->
	<parameter name="Kafka_BootstrapServers"
		   description="Kafka bootstrap servers"
		   defaultValue="#{ConfluentPlatform.BootstrapServers}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:BootstrapServers']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_SchemaRegistryUrl"
		   description="Kafka Schema Registry URL"
		   defaultValue="#{ConfluentPlatform.SchemaRegistryUrl}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:SchemaRegistryUrl']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_SchemaRegistryBasicAuthUserInfo"
		   description="Kafka Schema Registry Basic Auth User Info"
		   defaultValue="#{ConfluentPlatform.SchemaRegistryBasicAuthUserInfo}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:SchemaRegistryBasicAuthUserInfo']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_SaslUsername"
		   description="Kafka SASL Username"
		   defaultValue="#{ConfluentPlatform.SaslUsername}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:SaslUsername']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_SaslPassword"
		   description="Kafka SASL Password"
		   defaultValue="#{ConfluentPlatform.SaslPassword}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:SaslPassword']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_Topic"
		   description="Kafka Topic for Unified Login User Status"
		   defaultValue="#{ConfluentPlatform.UserStatusTopicName}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:UserStatusTopicName']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_OnPrem"
		   description="Kafka OnPrem"
		   defaultValue="#{ConfluentPlatform.OnPrem}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:OnPrem']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>
	<parameter name="Kafka_SslCaCertificateStores"
	   description="Kafka SslCaCertificateStores"
	   defaultValue="#{ConfluentPlatform.SSLCACertificateStores}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='Kafka:SslCaCertificateStores']/@value" />
		<parameterValidation kind="AllowEmpty" />
	</parameter>

	<!--APM settings-->
	<parameter name="ElasticApm_Enabled"
		   description="Flag to on and off the APM"
		   defaultValue="#{ElasticApm.Enabled}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:Enabled']/@value" />
	</parameter>
	<parameter name="Environment"
			    description="Used by APM"
			    defaultValue="#{Environment}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:Environment']/@value" />
	</parameter>
	<parameter name="ElasticApm_ServerUrl"
		   description="APM Server Url"
		   defaultValue="#{ElasticApm.ServerUrl}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:ServerUrl']/@value" />
	</parameter>
	<parameter name="ElasticApm_ServiceVersion"
		   description="APM Server Version / Branch Name"
		   defaultValue="#{ElasticApm.ServiceVersion}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:ServiceVersion']/@value" />
	</parameter>
	<parameter name="ElasticApm_TransactionSampleRate"
		   description="TransactionSampleRate 1.0 for lower and 0.1 for PROD"
		   defaultValue="#{ElasticApm.TransactionSampleRate}#">
		<parameterEntry kind="XmlFile" scope="Web.config" match="/configuration/appSettings/add[@key='ElasticApm:TransactionSampleRate']/@value" />
	</parameter>
</parameters>