#scp "vradmin@10.34.26.22:D:\Identity\prod\DB_Deploy\*" "vradmin@10.34.26.21:D:\Identity\" -o Password="Admin@1234" 
# Source server information
$sourceServer = "10.34.26.22"
$sourceUsername = "vradmin"
$sourcePassword = "Admin@1234"  # Note: Avoid storing passwords in scripts for security reasons
$sourcePath = "D:\Identity\prod\DB_Deploy\DB_Identity\"
# Destination server information
$destinationServer = "10.34.26.21"
$destinationUsername = "vradmin"
$destinationPassword = "Admin@1234"  # Note: Avoid storing passwords in scripts for security reasons
$destinationPath = "D:\Identity\"
# Convert the password to a secure string
$secureSourcePassword = ConvertTo-SecureString -String $sourcePassword -AsPlainText -Force
$secureDestinationPassword = ConvertTo-SecureString -String $destinationPassword -AsPlainText -Force
# Create PSCredential objects
$sourceCredential = New-Object -TypeName PSCredential -ArgumentList $sourceUsername, $secureSourcePassword
$destinationCredential = New-Object -TypeName PSCredential -ArgumentList $destinationUsername, $secureDestinationPassword