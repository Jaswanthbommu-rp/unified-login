    <DataSet Name="DSet_Products">
      <Query>
        <DataSourceName>DS_Users</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CompanyId">
            <Value>=Parameters!CompanyId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DECLARE @PartyId BIGINT
   
DECLARE @NOW  DATETIME = GETUTCDATE();  

SELECT	@PartyId = PartyId
FROM	Enterprise.Party
WHERE	RealPageId = @CompanyId  


SELECT ' ALL' AS ProductName

UNION ALL

SELECT DISTINCT pr.[Name] AS ProductName 
FROM [Enterprise].OrganizationProduct op 
    INNER  JOIN [Enterprise].[Product] pr ON pr.ProductId = op.ProductId    
WHERE (op.PartyId = @PartyId)  
	AND ((@NOW BETWEEN op.FromDate AND op.ThruDate) OR (@NOW &gt;= op.FromDate AND op.ThruDate IS NULL))   
	AND pr.[Active]  = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProductName">
          <DataField>ProductName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_UserType">
      <Query>
        <DataSourceName>DS_Users</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CompanyId">
            <Value>=Parameters!CompanyId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
DECLARE @RoleTypeName NVARCHAR(100)= 'User Role' 
DECLARE @PartyId BIGINT

SELECT	@PartyId = PartyId
FROM	Enterprise.Party
WHERE	RealPageId = @CompanyId  
      
SELECT ' ALL' AS UserType

UNION ALL

SELECT  DISTINCT 
	RT1.[Name] AS UserType
FROM enterprise.roletype rt  
INNER JOIN  enterprise.roletype rt1 ON rt1.Parentpartyroletypeid = rt.partyroletypeid  
INNER JOIN  enterprise.partyrole pr ON pr.roletypeid = rt1.PartyRoleTypeId  
WHERE ( RT.[Name] = @RoleTypeName)  
        AND  (pr.PartyId = @PartyId)  
ORDER BY UserType
</CommandText>
      </Query>
      <Fields>
        <Field Name="UserType">
          <DataField>UserType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_UserStatus">
      <Query>
        <DataSourceName>DS_Users</DataSourceName>
        <CommandText>SELECT ' ALL' AS UserStatus  

UNION ALL 

SELECT est.[Name] AS UserStatus  
 FROM Enterprise.StatusTypeCategoryType estct  
    INNER JOIN Enterprise.StatusTypeCategory estc ON estc.StatusTypeCategoryTypeId = estct.StatusTypeCategoryTypeId  
    INNER JOIN Enterprise.StatusTypeCategoryClassification estcc ON estcc.StatusTypeCategoryId = estc.StatusTypeCategoryId  
    INNER JOIN Enterprise.StatusType est ON est.StatusTypeId = estcc.StatusTypeId  
 WHERE estct.Name = 'Status'
 AND  estc.Name = 'User Status'
 ORDER BY UserStatus  </CommandText>
      </Query>
      <Fields>
        <Field Name="UserStatus">
          <DataField>UserStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DSet_PlatformRoles">
      <Query>
        <DataSourceName>DS_Users</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CompanyId">
            <Value>=Parameters!CompanyId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DECLARE @PartyId BIGINT

SELECT	@PartyId = PartyId
FROM	Enterprise.Party
WHERE	RealPageId = @CompanyId  

SELECT ' ALL' AS PlatformRole 

UNION ALL

SELECT RoleName AS PlatformRole 
FROM [Security].[Role] 
WHERE OrgPartyID = @PartyId</CommandText>
      </Query>
      <Fields>
        <Field Name="PlatformRole">
          <DataField>PlatformRole</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
